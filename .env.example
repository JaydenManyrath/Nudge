ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_REDIRECT_URI=http://localhost:5000/auth/zoom/callback
ZOOM_SCOPES=meeting:read:meeting_transcript
ZOOM_SECRET_TOKEN=

OPENAI_API_KEY=
OPENAI_EXTRACTION_MODEL=gpt-4o-mini

# Use "openai" for real transcript extraction. Use "deterministic" for local
# sample/demo runs and tests that should not require network credentials.
NUDGE_EXTRACTION_BACKEND=deterministic

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5000/auth/google/callback
GOOGLE_CALENDAR_SCOPES=https://www.googleapis.com/auth/calendar.events

SENDGRID_API_KEY=

SECRET_KEY=

# Vercel sets VERCEL_URL / VERCEL_PROJECT_PRODUCTION_URL automatically. Set
# PUBLIC_BASE_URL for custom domains or when overriding platform-provided URLs,
# e.g. https://nudge.example.com.
PUBLIC_BASE_URL=

# Local default is ./nudge.db. Vercel container deployments default this to
# /var/data/nudge.db; attach persistent storage if production data must survive
# instance replacement.
NUDGE_DB_PATH=
NUDGE_SEED_DEMO_DATA=true

DUE_SOON_HOURS=24
